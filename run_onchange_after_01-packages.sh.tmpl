#!/bin/bash
set -euo pipefail

# ------------------------------------------------------------------------------
# Core Package Installation
# ------------------------------------------------------------------------------
# Curated core packages + casks (macOS only). This is the declared/target
# state — if a machine's `brew list` has drifted beyond this list, that's
# accumulated manual installs, not a reflection of what this script defines.
# ------------------------------------------------------------------------------

echo "📦 Installing core packages ..."

{{- if eq .chezmoi.os "darwin" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- else }}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null || true)"
{{- end }}

packages=(
  # --- Core ---
  bash
  bat
  delta
  direnv
  eza
  fd
  fzf
  gh
  git
  git-lfs
  glow
  jq
  mise
  ripgrep
  starship
  tldr
  tmux
  tree
  vim
  wget
  yq
  zoxide
  zsh-autosuggestions
  zsh-syntax-highlighting

  # --- Cloud CLIs ---
  awscli
  azure-cli
)

for pkg in "${packages[@]}"; do
    if brew list "$pkg" &>/dev/null; then
        echo "✅ $pkg"
    else
        brew install "$pkg"
    fi
done

{{- if eq .chezmoi.os "darwin" }}
# Casks - MacOS only
casks=(
  # --- Core ---
  alfred
  ghostty
  visual-studio-code

  # --- Cloud ---
  google-cloud-sdk

  # --- Dev tools ---
  docker-desktop
  jetbrains-toolbox
  # insomnia

  # --- Productivity ---
  firefox
  obsidian
  rectangle
)

for cask in "${casks[@]}"; do
    if brew list --cask "$cask" &>/dev/null; then
        echo "✅ $cask (brew)"
    else
        output=$(brew install --cask "$cask" 2>&1) || {
            if echo "$output" | grep -q "already an App"; then
                echo "✅ $cask (external)"
            else
                echo "❌ $cask failed: $output"
            fi
        }
    fi
done
{{- end }}

# --- mise-managed languages ---
if command -v mise &>/dev/null; then
  echo "🔧 Installing mise-managed languages..."
  mise install
fi

# --- Go tools ---
if command -v go &>/dev/null; then
  echo "🔧 Installing Go tools..."
  go install github.com/bootdotdev/bootdev@latest
fi

echo "📁 Creating directories..."
mkdir -p ~/code/{work,personal}

echo "✅ Done"
