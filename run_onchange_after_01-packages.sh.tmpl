#!/bin/bash
set -euo pipefail

echo "📦 Installing core packages ..."

{{- if eq .chezmoi.os "darwin" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- else }}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null || true)"
{{- end }}

packages=(
  bash
  git
  vim
  jq
  yq
  wget
  mise
  starship
  bat
  tree
  tmux
  git-lfs
  glow
  eza
  zoxide
  fzf
)

for pkg in "${packages[@]}"; do
    if brew list "$pkg" &>/dev/null; then
        echo "✅ $pkg"
    else
        brew install "$pkg"
    fi
done

{{- if eq .chezmoi.os "darwin" }}
# Casks - MacOS only
casks=(
  ghostty
  visual-studio-code
)

for cask in "${casks[@]}"; do
    if brew list --cask "$cask" &>/dev/null; then
        echo "✅ $cask (brew)"
    else
        output=$(brew install --cask "$cask" 2>&1) || {
            if echo "$output" | grep -q "already an App"; then
                echo "✅ $cask (external)"
            else
                echo "❌ $cask failed: $output"
            fi
        }
    fi
done
{{- end }}

echo "📁 Creating directories..."
mkdir -p ~/code/{work,personal}

echo "✅ Done"
