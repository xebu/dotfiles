" ------------------------------------------------------------------------------
" Vim Configuration
" ------------------------------------------------------------------------------

" --- Core ---

syntax on
set number
set relativenumber
set tabstop=2
set shiftwidth=2
set expandtab
set autoindent
set background=dark

" --- Snippets ---
" Note: section-divider/header snippets below use "#"-style comments,
" intended for shell/config/TOML files rather than vim/Go/etc.

" Section divider: \d in normal mode
" Types "# ---  ---" and positions cursor between the dashes to type a label
nnoremap <leader>d i# ---  ---<Esc>hhi

" File header: \h in normal mode
nnoremap <leader>h i# ------------------------------------------------------------------------------<CR># <CR># ------------------------------------------------------------------------------<Esc>kA
