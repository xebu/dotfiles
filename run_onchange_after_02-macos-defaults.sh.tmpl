{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# ------------------------------------------------------------------------------
# macOS System Defaults
# ------------------------------------------------------------------------------
# Applies personal macOS preferences for:
# - Finder
# - Dock
# - Mission Control
# - Keyboard
# - Screenshots
# - Scrollbars
# - Menu bar (battery percentage, Bluetooth)
#
# These are personal preferences, not a recommended baseline — fork and
# adjust the `defaults write` values below to taste if reusing this repo.
# ------------------------------------------------------------------------------

set -euo pipefail

echo "⚙️ Applying macOS system defaults..."

# --- Finder ---
echo "🪟 Configuring Finder..."
defaults write com.apple.finder AppleShowAllFiles -bool true
defaults write com.apple.finder ShowPathbar -bool true
defaults write com.apple.finder ShowStatusBar -bool true
defaults write com.apple.finder QuitMenuItem -bool true
defaults write com.apple.finder _FXSortFoldersFirst -bool true
defaults write NSGlobalDomain NSTableViewDefaultSizeMode -int 1

# --- Dock ---
echo "🧭 Configuring Dock..."
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock autohide-delay -float 0
# NOTE: autohide-time-modifier must be a float; -int 0 can be ignored by the Dock.
defaults write com.apple.dock autohide-time-modifier -float 0
defaults write com.apple.dock tilesize -int 36
defaults write com.apple.dock mineffect -string "scale"
defaults write com.apple.dock minimize-to-application -bool true
defaults write com.apple.dock show-process-indicators -bool true
defaults write com.apple.dock orientation -string "left"
defaults write com.apple.dock show-recents -bool false

# --- Mission Control ---
echo "🚀 Configuring Mission Control..."
defaults write com.apple.dock mru-spaces -bool false
defaults write com.apple.dock expose-group-apps -bool true

# --- Keyboard ---
echo "⌨️ Configuring Keyboard..."
defaults write NSGlobalDomain KeyRepeat -int 2
defaults write NSGlobalDomain InitialKeyRepeat -int 15
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

# --- Screenshots ---
echo "📸 Configuring Screenshots..."
# NOTE: target=clipboard means screenshots go to the clipboard, not disk —
# so `type` and `disable-shadow` below have no effect on the default capture
# path. Kept for when target is switched back to "file".
defaults write com.apple.screencapture target -string "clipboard"
defaults write com.apple.screencapture type -string "png"
defaults write com.apple.screencapture disable-shadow -bool true

# --- Scrollbars ---
echo "🖱️ Setting scrollbars to always show..."
defaults write NSGlobalDomain AppleShowScrollBars -string "Always"

# --- Spaces (Ctrl+1/2/3 to switch) ---
echo "🖥️ Configuring Spaces shortcuts..."
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 118 "{ enabled = 1; value = { parameters = (65535, 18, 262144); type = standard; }; }"
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 119 "{ enabled = 1; value = { parameters = (65535, 19, 262144); type = standard; }; }"
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 120 "{ enabled = 1; value = { parameters = (65535, 20, 262144); type = standard; }; }"

# --- Menu Bar ---
# Lab note (2026-06-22): Bluetooth key is "NSStatusItem VisibleCC Bluetooth"
# (not "Visible"). Also requires per-host Bluetooth=2 for "Show in Menu Bar".
echo "📶 Configuring Menu Bar..."
defaults write com.apple.controlcenter "NSStatusItem VisibleCC Bluetooth" -bool true
defaults -currentHost write com.apple.controlcenter Bluetooth -int 2

# --- Battery (laptops only) ---
# Lab note (2026-06-21): verified against odin (M5 Max, Mac17,7) and thor
# (M2 Max, Mac14,5), macOS 26. Findings:
#   - The battery SYMBOL is visible by default on laptops. macOS sets
#     `NSStatusItem VisibleCC Battery = 1` itself — no script line needed.
#   - The old `NSStatusItem Visible Battery` key (no "CC") is a DEAD KEY on
#     macOS 26: wrong name AND redundant. Removed.
#   - Battery PERCENTAGE is the only part not on by default. It's a per-host
#     key and is the single line worth keeping here.
#   - LAPTOP DETECTION: `hw.model` no longer contains "MacBook" on recent
#     Apple Silicon — it returns MacN,N identifiers (Mac14,5, Mac17,7) with no
#     family word. The old `contains "MacBook"` test was false on EVERY modern
#     laptop, silently skipping this block. Detect a battery directly instead.
{{- $isLaptop := (output "pmset" "-g" "batt" | contains "InternalBattery") }}
{{- if $isLaptop }}
echo "🔋 Enabling battery percentage (laptop detected)..."
defaults -currentHost write com.apple.controlcenter BatteryShowPercentage -bool true
{{- else }}
echo "🖥️ Desktop detected — skipping battery percentage"
{{- end }}

# --- Trackpad ---
# Values lifted from the MBA (primary dev machine) where these work, not guessed:
#   tap-to-click: Clicking=1 in BOTH trackpad domains + tapBehavior=1 global.
#   All three are required for tap-to-click to fully stick.
#   tracking speed: com.apple.trackpad.scaling=2.5 (float, ~0-3, higher=faster).
echo "👆 Configuring Trackpad..."
# Tap to click
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
defaults write NSGlobalDomain com.apple.mouse.tapBehavior -int 1
# Tracking speed
defaults write NSGlobalDomain com.apple.trackpad.scaling -float 2.5

# --- Restart affected services ---
echo "♻️ Restarting UI services..."
killall Dock || true
killall Finder || true
killall SystemUIServer || true
# ControlCenter must be restarted for battery/menu-bar changes to take effect.
killall ControlCenter || true
/System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u

echo "✅ macOS defaults applied"
echo ""
echo "⚠️  Some settings require logout/restart to take effect"
{{- end }}
