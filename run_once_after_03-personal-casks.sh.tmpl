{{- if and (eq .chezmoi.os "darwin") (.personal_device | default false) -}}
#!/usr/bin/env bash
set -euo pipefail

# ------------------------------------------------------------------------------
# Personal Applications
# ------------------------------------------------------------------------------
# Installed only on personal devices (personal_device = true).
# ------------------------------------------------------------------------------

echo "🎵 Installing personal applications..."

apps=(
  # --- Messaging ---
  whatsapp
  discord
  signal

  # --- Media ---
  spotify
  vlc

  # --- Browsers ---
  brave-browser
  helium-browser

  # --- AI/LLM ---
  claude
  claude-code
  lm-studio

  # --- Dev ---
  ngrok

  # --- Utilities ---
  balenaetcher

  # --- VPN ---
  nordvpn
)

for app in "${apps[@]}"; do
  if brew list --cask "$app" &>/dev/null; then
    echo "✅ $app already installed"
  else
    echo "📦 Installing $app..."
    brew install --cask "$app"
  fi
done

echo "✅ Personal applications installed."
{{- end }}
